# ===========================================
# MARKET BOT v26 — Configuration
# ===========================================
# Rename this file to .env and fill in your values.
# No quotes needed. No spaces around the = sign.

# --- Telegram ---
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- Claude API (get from console.anthropic.com) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- IBKR TWS/Gateway (primary data source) ---
# Open TWS → File → Global Configuration → API → Settings
# Enable ActiveX and Socket Clients, allow connections from localhost
IBKR_HOST=127.0.0.1
IBKR_PORT=7496
# Ports: 7497=TWS paper, 7496=TWS live, 4002=Gateway paper, 4001=Gateway live
IBKR_CLIENT_ID=10

# --- Risk Management ---
ACCOUNT_SIZE=50000
MAX_RISK_PCT=2.0
MAX_DAILY_LOSS=-50000.0
